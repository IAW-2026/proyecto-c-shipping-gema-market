// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  buyer
}

enum OrdenStatus {
  created
  awaiting_payment
  paid
  shipping
  delivered
  shipping_failed
  cancelled
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Usuario {
  id            String   @id @db.VarChar(50) // prefixed ULID: usr_<26-char-ulid>
  clerkUserId   String   @unique @db.VarChar(255) @map("clerk_user_id")
  email         String   @db.VarChar(255)
  fullName      String   @db.VarChar(255) @map("full_name")
  phoneNumber   String?  @map("phone_number")
  address       Json?
  role          Role     @default(buyer)
  createdAt     DateTime @default(now()) @map("created_at")

  ordenes       Orden[]
  carrito       Carrito?
  favoritos     Favorito[]

  @@map("usuario")
}

model Orden {
  id             String      @id @db.VarChar(30)
  buyerId        String      @map("buyer_id")
  sellerId       String      @map("seller_id")       // FK lógica → Seller App
  productId      String      @map("product_id")      // FK lógica → Seller App
  quantity       Int
  unitPrice      Decimal     @map("unit_price")       @db.Decimal(12, 2)
  quoteId        String?     @map("quote_id")         // FK lógica → Shipping App
  shippingPrice  Int         @map("shipping_price")
  totalAmount    Decimal     @map("total_amount")     @db.Decimal(12, 2)
  currency       String      @default("ARS")          @db.VarChar(3)
  status         OrdenStatus @default(created)
  paymentId      String?     @map("payment_id")       // FK lógica → Payments App
  shippingId     String?     @map("shipping_id")      // FK lógica → Shipping App
  createdAt      DateTime    @default(now())           @map("created_at")
  updatedAt      DateTime    @updatedAt                @map("updated_at")

  buyer          Usuario     @relation(fields: [buyerId], references: [id])

  @@map("orden")
}

model Carrito {
  id        String       @id @db.VarChar(30)
  buyerId   String       @unique @map("buyer_id")
  createdAt DateTime     @default(now()) @map("created_at")

  buyer     Usuario      @relation(fields: [buyerId], references: [id])
  items     ItemCarrito[]

  @@map("carrito")
}

model ItemCarrito {
  id         String   @id @db.VarChar(30)
  carritoId  String   @map("carrito_id")
  productId  String   @map("product_id")  // FK lógica → Seller App
  quantity   Int
  addedAt    DateTime @default(now()) @map("added_at")

  carrito    Carrito  @relation(fields: [carritoId], references: [id], onDelete: Cascade)

  // Un mismo producto solo puede aparecer una vez por carrito
  @@unique([carritoId, productId])
  @@map("item_carrito")
}

model Favorito {
  buyerId    String   @map("buyer_id")
  productId  String   @map("product_id")  // FK lógica → Seller App
  createdAt  DateTime @default(now()) @map("created_at")

  buyer      Usuario  @relation(fields: [buyerId], references: [id])

  @@id([buyerId, productId])
  @@map("favorito")
}