# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# PostgreSQL (Supabase / Neon / Railway)
DATABASE_URL=postgresql://user:password@host:5432/db
DIRECT_URL=postgresql://user:password@host:5432/db

# OpenRouteService (https://openrouteservice.org)
ORS_API_KEY=xxx

# API keys for inter-service communication
INTERNAL_API_KEY=xxx
NEXT_PUBLIC_INTERNAL_API_KEY_HASH=xxx

# External apps URLs (Etapa 3)
# Dejar MOCK_EXTERNAL_APIS=true para usar mocks, false o vacío para llamar a las APIs reales
BUYER_API_URL=https://proyecto-c-buyer-gema-market.vercel.app
SELLER_API_URL=https://proyecto-c-seller-gema-market.vercel.app


# Mock external APIs during development
MOCK_EXTERNAL_APIS=true
