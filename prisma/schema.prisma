// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// 1. User: Cache sincronizado de Clerk
model User {
  id            String   @id // Generado en código: 'usr_' + ulid()
  clerk_user_id String   @unique // Fuente de verdad global
  email         String
  full_name     String
  role          String   @default("logistics") // Solo roles relevantes para esta app
  banned        Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz()

  // Relaciones internas
  shipments Shipment[]
}

// 2. Quote: Datos previos al envío
model Quote {
  id                    String   @id // Generado en código: 'qte_' + ulid()
  product_id            String // FK lógica -> Seller App
  status                String   @default("available") // available, reserved, confirmed
  reserved_for_order_id String? // FK lógica -> Buyer App
  package_details       Json // { "weight": 2.5, "width": 20, "height": 10, "depth": 30, "unit": "kg/cm" }
  origin_address        Json // Datos de calle, nro, etc.
  destination_address   Json
  price                 Decimal  @db.Decimal(10, 2)
  currency              String   @default("ARS")
  estimated_days        Int
  valid_until           DateTime @db.Timestamptz()
  created_at            DateTime @default(now()) @db.Timestamptz()

  pickup_lat            Float?
  pickup_lng            Float?
  delivery_lat          Float?
  delivery_lng          Float?
  route_distance        Float?
  route_duration        Float?
}

// 3. Shipment: Entidad maestra de logística
model Shipment {
  id               String    @id // Generado en código: 'shp_' + ulid()
  order_id         String    @unique // FK lógica -> Buyer App
  quote_id         String    // FK lógica para trazar el origen del envío
  buyer_id         String // FK lógica
  receiver_name    String // Nombre de quien recibe
  receiver_phone   String // Teléfono de contacto para la entrega
  seller_id        String // FK lógica
  logistics_id     String? // FK física -> User local (fletero)
  weight           Decimal   @db.Decimal(10, 2)
  dimensions       Json // { "width": 20, "height": 10, "depth": 30 }
  pickup_address   Json
  delivery_address Json
  tracking_code    String    @unique
  status           String    @default("waiting_for_courier") // waiting_for_courier, pending_pickup, picked_up, in_transit, delivered
  price            Decimal   @db.Decimal(10, 2)
  picked_up_at     DateTime? @db.Timestamptz()
  delivered_at     DateTime? @db.Timestamptz()
  created_at       DateTime  @default(now()) @db.Timestamptz()

  pickup_lat       Float?
  pickup_lng       Float?
  delivery_lat     Float?
  delivery_lng     Float?
  route_geometry   Json?
  route_distance   Float?
  route_duration   Float?

  // Relación con el fletero asignado
  operator User? @relation(fields: [logistics_id], references: [id])
}

// 4. Rate: Configuración de precios por peso facturable (USD/km)
model Rate {
  id           String  @id // Generado en código: 'trf_' + ulid()
  weight_range Json // Ejemplo: { "min": 0, "max": 30 }
  price_per_km Decimal @db.Decimal(10, 2) // USD por km
}

// 5. TrackingSequence: Secuencia atómica para tracking codes por año
model TrackingSequence {
  year        Int @id
  last_number Int
}
